<Window x:Class="SuperCalcBenchmark.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SuperCalc Benchmark"
        Icon="pack://application:,,,/SuperCalcBenchmark.App;component/assets/SuperCalc.png"
        Height="860" Width="1240" MinHeight="720" MinWidth="1050"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="Auto">

    <Grid Margin="14" Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="4,0,4,8" LastChildFill="False">
            <StackPanel DockPanel.Dock="Left">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="SuperCalc Security Benchmark" FontSize="24" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <ComboBox x:Name="ThemeComboBox"
                              Width="118"
                              Margin="16,0,0,0"
                              SelectedIndex="0"
                              SelectionChanged="ThemeComboBox_SelectionChanged"
                              ToolTip="Theme wählen">
                        <ComboBoxItem Content="Light" />
                        <ComboBoxItem Content="Dark" />
                    </ComboBox>
                </StackPanel>
                <TextBlock Text="Llama.cpp-Server refreshen, Modell auswählen, Benchmark starten — Run 3 Truth-Audit läuft automatisch mit." Foreground="{DynamicResource TextSecondaryBrush}" />
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="UpdateButton"
                        Content="Update ziehen"
                        Margin="0,0,12,0"
                        Click="UpdateButton_Click"
                        ToolTip="Git-Checkout: führt git pull --ff-only aus. Standalone-EXE: lädt das neueste GitHub-Release herunter und startet die App neu. Lokale Benchmarkdaten in archive/, artifacts/ und results/ werden nie überschrieben." />
                <TextBlock x:Name="DotNetInfoTextBlock" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" />
            </StackPanel>
        </DockPanel>

        <GroupBox Grid.Row="1" Header="Benchmark starten">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Server" VerticalAlignment="Center" Margin="4" />
                <TextBox x:Name="ServerUrlTextBox" Grid.Row="0" Grid.Column="1" Text="http://127.0.0.1:1234" />
                <Button x:Name="RefreshModelsButton" Grid.Row="0" Grid.Column="2" Content="Refresh Models" Click="RefreshModelsButton_Click" />

                <TextBlock Grid.Row="0" Grid.Column="3" Text="Modell" VerticalAlignment="Center" Margin="12,4,4,4" />
                <ComboBox x:Name="ModelComboBox" Grid.Row="0" Grid.Column="4" IsEditable="False" SelectionChanged="ModelComboBox_SelectionChanged" />
                <TextBlock Grid.Row="0" Grid.Column="5" Text="Durchläufe" VerticalAlignment="Center" Margin="12,4,4,4" />
                <TextBox x:Name="RepeatCountTextBox" Grid.Row="0" Grid.Column="6" Text="1" Width="52" VerticalAlignment="Center" ToolTip="Anzahl kompletter Benchmark-Durchläufe (je Run 1 + Run 2 + Run 3) direkt hintereinander. Jeder Durchlauf wird einzeln archiviert — z.B. 30 für kleine Modelle über Nacht." />
                <Button x:Name="StartBenchmarkButton" Grid.Row="0" Grid.Column="7" Content="Benchmark starten" FontWeight="SemiBold" Click="StartBenchmarkButton_Click" />
                <Button x:Name="CancelBenchmarkButton" Grid.Row="0" Grid.Column="8" Content="Abbrechen" IsEnabled="False" Click="CancelBenchmarkButton_Click" ToolTip="Bricht den laufenden Durchlauf ab; weitere geplante Durchläufe werden ebenfalls gestoppt." />

                <Expander Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="9" Header="Optionen" Margin="4,8,4,0" IsExpanded="False">
                    <WrapPanel Margin="0,8,0,0">
                        <TextBlock Text="Max Tokens (-1=max)" VerticalAlignment="Center" Margin="4" />
                        <TextBox x:Name="MaxTokensTextBox" Text="-1" Width="90" ToolTip="-1 (empfohlen für Reasoning-Modelle): kein Limit, llama.cpp generiert bis EOS/Kontext/Timeout — Thinking UND finale Antwort haben Platz. Eine feste Zahl teilt sich das Budget zwischen Thinking und Antwort; bei denkenden Modellen kann dann die Antwort leer bleiben." />
                        <TextBlock Text="Timeout (Sek.)" VerticalAlignment="Center" Margin="12,4,4,4" />
                        <TextBox x:Name="TimeoutTextBox" Text="14400" Width="90" ToolTip="4h pro Request: ausgelegt für große lokale Reasoning-Modelle mit ca. 3 tok/s, ~80k Thinking-Zeichen plus finale Antwort und Prompt-Lesezeit." />
                        <TextBlock Text="Seed" VerticalAlignment="Center" Margin="12,4,4,4" />
                        <TextBox x:Name="SeedTextBox" Text="12345" Width="90" />
                        <CheckBox x:Name="SkipResponseFormatCheckBox" Content="response_format überspringen" IsChecked="True" VerticalAlignment="Center" Margin="16,4,4,4" ToolTip="Kompatibler mit llama-web-ui; JSON wird weiterhin per Parser extrahiert." />
                        <CheckBox x:Name="DisableThinkingCheckBox" Content="Thinking deaktivieren (Debug)" IsChecked="False" VerticalAlignment="Center" Margin="16,4,4,4" />
                        <TextBlock Text="Quant (optional)" VerticalAlignment="Center" Margin="16,4,4,4" />
                        <TextBox x:Name="QuantTextBox" Width="110" ToolTip="Leer lassen für Auto-Erkennung. Nur setzen, wenn Modell-ID/Server den Quant nicht liefern; Refresh Models leert manuelle Werte." />
                        <Button x:Name="PreviewPromptButton" Content="Prompt anzeigen" Margin="16,4,4,4" Click="PreviewPromptButton_Click" ToolTip="Zeigt den generierten Prompt und die erste Request-JSON, ohne den Server aufzurufen." />
                        <TextBlock Text="Output-Ordner optional" VerticalAlignment="Center" Margin="16,4,4,4" />
                        <TextBox x:Name="OutputDirectoryTextBox" Width="320" ToolTip="Leer lassen für %LOCALAPPDATA%\SuperCalcBenchmark\Runs" />
                    </WrapPanel>
                </Expander>
            </Grid>
        </GroupBox>

        <TabControl Grid.Row="2" Margin="4">
            <TabItem Header="Übersicht">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <UniformGrid Grid.Row="0" Columns="4" Margin="0,0,0,10">
                        <Border BorderBrush="{DynamicResource BorderBrush}" Background="{DynamicResource SurfaceBrush}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="4">
                            <StackPanel>
                                <TextBlock Text="Run 1 — Blind Analysis" FontWeight="SemiBold" FontSize="16" />
                                <TextBlock x:Name="Run1ScoreTextBlock" Text="Noch nicht gestartet" FontSize="26" FontWeight="Bold" Margin="0,8,0,0" />
                                <TextBlock x:Name="Run1DetailsTextBlock" Text="" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}" />
                            </StackPanel>
                        </Border>
                        <Border BorderBrush="{DynamicResource BorderBrush}" Background="{DynamicResource SurfaceBrush}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="4">
                            <StackPanel>
                                <TextBlock Text="Run 2 — Self-Validation" FontWeight="SemiBold" FontSize="16" />
                                <TextBlock x:Name="Run2ScoreTextBlock" Text="Noch nicht gestartet" FontSize="26" FontWeight="Bold" Margin="0,8,0,0" />
                                <TextBlock x:Name="Run2DetailsTextBlock" Text="" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}" />
                            </StackPanel>
                        </Border>
                        <Border BorderBrush="{DynamicResource BorderBrush}" Background="{DynamicResource SurfaceBrush}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="4">
                            <StackPanel>
                                <TextBlock Text="Run 3 — Truth Audit" FontWeight="SemiBold" FontSize="16" />
                                <TextBlock x:Name="Run3ScoreTextBlock" Text="Läuft automatisch mit" FontSize="26" FontWeight="Bold" Margin="0,8,0,0" />
                                <TextBlock x:Name="Run3DetailsTextBlock" Text="Non-blind Ehrlichkeits-/Accountability-Test nach Run 2" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}" />
                            </StackPanel>
                        </Border>
                        <Border BorderBrush="{DynamicResource BorderBrush}" Background="{DynamicResource SurfaceBrush}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="4">
                            <StackPanel>
                                <TextBlock Text="Self-Validation Effekt" FontWeight="SemiBold" FontSize="16" />
                                <TextBlock x:Name="ComparisonTextBlock" Text="Nach dem Benchmark sichtbar" FontSize="15" TextWrapping="Wrap" Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <TextBlock Grid.Row="1" x:Name="StatusTextBlock" Text="Bereit. Starte llama-server und klicke Refresh Models." Margin="4" Foreground="{DynamicResource TextSecondaryBrush}" />

                    <GroupBox Grid.Row="2" Header="Fortschritt">
                        <TextBox x:Name="ProgressLogTextBox" IsReadOnly="True" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" TextWrapping="NoWrap" FontFamily="Consolas" />
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="Run 1 Matrix">
                <DataGrid x:Name="Run1MatrixGrid" Margin="8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="100" />
                        <DataGridCheckBoxColumn Header="Found" Binding="{Binding Found}" Width="70" />
                        <DataGridCheckBoxColumn Header="Partial" Binding="{Binding Partial}" Width="70" />
                        <DataGridTextColumn Header="Finding" Binding="{Binding FindingIndex}" Width="80" />
                        <DataGridTextColumn Header="Match" Binding="{Binding MatchScore, StringFormat=0.000}" Width="80" />
                        <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="90" />
                        <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Run 2 Matrix">
                <DataGrid x:Name="Run2MatrixGrid" Margin="8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="100" />
                        <DataGridCheckBoxColumn Header="Found" Binding="{Binding Found}" Width="70" />
                        <DataGridCheckBoxColumn Header="Partial" Binding="{Binding Partial}" Width="70" />
                        <DataGridTextColumn Header="Finding" Binding="{Binding FindingIndex}" Width="80" />
                        <DataGridTextColumn Header="Match" Binding="{Binding MatchScore, StringFormat=0.000}" Width="80" />
                        <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="90" />
                        <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Finding Ledger">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <GroupBox Grid.Row="0" Header="Run 1 Findings">
                        <DataGrid x:Name="Run1FindingsGrid">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding FindingIndex}" Width="45" />
                                <DataGridTextColumn Header="Class" Binding="{Binding Classification}" Width="150" />
                                <DataGridTextColumn Header="Points" Binding="{Binding Points, StringFormat=0.##}" Width="70" />
                                <DataGridTextColumn Header="Match" Binding="{Binding MatchScore, StringFormat=0.000}" Width="70" />
                                <DataGridTextColumn Header="GT" Binding="{Binding MatchedVulnerabilityId}" Width="100" />
                                <DataGridTextColumn Header="Finding" Binding="{Binding FindingTitle}" Width="280" />
                                <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                    <GroupBox Grid.Row="1" Header="Run 2 Findings">
                        <DataGrid x:Name="Run2FindingsGrid">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding FindingIndex}" Width="45" />
                                <DataGridTextColumn Header="Class" Binding="{Binding Classification}" Width="150" />
                                <DataGridTextColumn Header="Points" Binding="{Binding Points, StringFormat=0.##}" Width="70" />
                                <DataGridTextColumn Header="Match" Binding="{Binding MatchScore, StringFormat=0.000}" Width="70" />
                                <DataGridTextColumn Header="GT" Binding="{Binding MatchedVulnerabilityId}" Width="100" />
                                <DataGridTextColumn Header="Finding" Binding="{Binding FindingTitle}" Width="280" />
                                <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="Run 3 Audit">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="Run3AuditSummaryTextBlock"
                               Text="Run 3 läuft automatisch nach Run 2. Danach erscheinen hier Ehrlichkeits-/Accountability-Metriken."
                               TextWrapping="Wrap"
                               Margin="4,0,4,8"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                    <DataGrid Grid.Row="1" x:Name="Run3AuditGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="100" />
                            <DataGridTextColumn Header="Actual" Binding="{Binding ActualStatus}" Width="110" />
                            <DataGridTextColumn Header="Self Assessment" Binding="{Binding SelfAssessment}" Width="180" />
                            <DataGridCheckBoxColumn Header="Correct" Binding="{Binding Correct}" Width="80" />
                            <DataGridCheckBoxColumn Header="Quote OK" Binding="{Binding QuoteValid}" Width="80" />
                            <DataGridCheckBoxColumn Header="Overclaim" Binding="{Binding Overclaim}" Width="90" />
                            <DataGridCheckBoxColumn Header="Laundering" Binding="{Binding EvidenceLaundering}" Width="100" />
                            <DataGridTextColumn Header="Previous Quote" Binding="{Binding PreviousOutputQuote}" Width="280" />
                            <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Raw Outputs">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <GroupBox Header="Run 1 — Prompt / Thinking / Output / Raw" Grid.Column="0" Margin="0,0,4,0">
                        <DockPanel>
                            <Button x:Name="AbortRun1Button"
                                    DockPanel.Dock="Top"
                                    Content="Run 1 manuell stoppen"
                                    IsEnabled="False"
                                    Margin="8,8,8,4"
                                    Click="AbortRun1Button_Click"
                                    ToolTip="Stoppt nur Run 1: bisherige Tokens/Thinking werden analysiert und danach läuft Run 2 weiter." />
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel x:Name="Run1RawPanel" Margin="8" />
                            </ScrollViewer>
                        </DockPanel>
                    </GroupBox>
                    <GroupBox Header="Run 2 — Prompt / Thinking / Output / Raw" Grid.Column="1" Margin="4,0,4,0">
                        <DockPanel>
                            <Button x:Name="AbortRun2Button"
                                    DockPanel.Dock="Top"
                                    Content="Run 2 manuell stoppen"
                                    IsEnabled="False"
                                    Margin="8,8,8,4"
                                    Click="AbortRun2Button_Click"
                                    ToolTip="Stoppt nur Run 2: bisherige Tokens/Thinking werden analysiert und danach läuft Run 3 automatisch." />
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel x:Name="Run2RawPanel" Margin="8" />
                            </ScrollViewer>
                        </DockPanel>
                    </GroupBox>
                    <GroupBox Header="Run 3 — Truth Audit / Honesty / Raw" Grid.Column="2" Margin="4,0,0,0">
                        <DockPanel>
                            <Button x:Name="AbortRun3Button"
                                    DockPanel.Dock="Top"
                                    Content="Run 3 manuell stoppen"
                                    IsEnabled="False"
                                    Margin="8,8,8,4"
                                    Click="AbortRun3Button_Click"
                                    ToolTip="Stoppt nur Run 3: bisherige Tokens/Thinking werden analysiert und gespeichert. Run 1/2 bleiben unverändert. Hilfreich, wenn Run 3 in einer Loop feststeckt." />
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel x:Name="Run3RawPanel" Margin="8" />
                            </ScrollViewer>
                        </DockPanel>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="Vergleich">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <WrapPanel Grid.Row="0" Margin="0,0,0,8">
                        <Button x:Name="RefreshComparisonButton" Content="Archiv neu laden" Click="RefreshComparisonButton_Click" />
                        <TextBlock Text="Modellfamilie" VerticalAlignment="Center" Margin="16,4,4,4" />
                        <ComboBox x:Name="FamilyFilterComboBox" Width="240" SelectionChanged="ComparisonFilter_Changed" ToolTip="Alle Modelle oder nur die Quants einer Familie vergleichen." />
                        <TextBlock Text="Wertung" VerticalAlignment="Center" Margin="16,4,4,4" />
                        <ComboBox x:Name="AggregateComboBox" Width="150" SelectionChanged="ComparisonFilter_Changed">
                            <ComboBoxItem Content="Durchschnitt" IsSelected="True" />
                            <ComboBoxItem Content="Median" />
                            <ComboBoxItem Content="Bester Run" />
                        </ComboBox>
                        <TextBlock Text="Run-Sicht" VerticalAlignment="Center" Margin="16,4,4,4" />
                        <ComboBox x:Name="RunViewComboBox" Width="140" SelectionChanged="ComparisonFilter_Changed">
                            <ComboBoxItem Content="Primary" IsSelected="True" />
                            <ComboBoxItem Content="Run 1" />
                            <ComboBoxItem Content="Run 2" />
                            <ComboBoxItem Content="Delta" />
                        </ComboBox>
                        <TextBlock Text="Metrik" VerticalAlignment="Center" Margin="16,4,4,4" />
                        <ComboBox x:Name="MetricComboBox" Width="180" SelectionChanged="ComparisonFilter_Changed">
                            <ComboBoxItem Content="Score" IsSelected="True" />
                            <ComboBoxItem Content="Critical Recall" />
                            <ComboBoxItem Content="F1" />
                            <ComboBoxItem Content="Stability" />
                            <ComboBoxItem Content="Run2-Delta" />
                            <ComboBoxItem Content="Evidence Fidelity" />
                            <ComboBoxItem Content="Hallucination" />
                            <ComboBoxItem Content="Accountability" />
                            <ComboBoxItem Content="Tokeneffizienz" />
                        </ComboBox>
                        <Button x:Name="OpenComparisonButton" Content="Diagramme öffnen (HTML)" Margin="16,4,4,4" Click="OpenComparisonButton_Click" IsEnabled="False" ToolTip="Erzeugt interaktive Vergleichsdiagramme als HTML und öffnet sie im Browser." />
                        <Button x:Name="OpenArchiveFolderButton" Content="Archiv bearbeiten" Click="OpenArchiveFolderButton_Click" ToolTip="Öffnet die Scorecard-JSONs. modelFamily/quant können manuell korrigiert werden; danach Archiv neu laden." />
                    </WrapPanel>

                    <TextBlock Grid.Row="1" x:Name="ComparisonStatusTextBlock" Margin="4,0,4,8" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"
                               Text="Archivierte Runs werden je Modell + Quant gruppiert. Scorecard-JSONs können im Archiv-Ordner manuell korrigiert werden (modelFamily/quant); danach 'Archiv neu laden' klicken." />

                    <DataGrid Grid.Row="2" x:Name="ComparisonGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              ColumnWidth="Auto"
                              EnableColumnVirtualization="False"
                              EnableRowVirtualization="False"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Modell" SortMemberPath="ModelFamily" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding ModelFamily, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                                 CaretBrush="{DynamicResource AccentBrush}"
                                                 Padding="2"
                                                 ToolTip="Modell per Doppelklick bearbeiten; Enter speichert, Esc verwirft."
                                                 GotKeyboardFocus="ComparisonEditableTextBox_GotKeyboardFocus"
                                                 LostKeyboardFocus="ComparisonEditableTextBox_LostKeyboardFocus"
                                                 PreviewMouseDoubleClick="ComparisonEditableTextBox_PreviewMouseDoubleClick"
                                                 KeyDown="ComparisonEditableTextBox_KeyDown" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Quant" SortMemberPath="Quant" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Quant, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                                 CaretBrush="{DynamicResource AccentBrush}"
                                                 Padding="2"
                                                 ToolTip="Quant per Doppelklick bearbeiten; Enter speichert, Esc verwirft."
                                                 GotKeyboardFocus="ComparisonEditableTextBox_GotKeyboardFocus"
                                                 LostKeyboardFocus="ComparisonEditableTextBox_LostKeyboardFocus"
                                                 PreviewMouseDoubleClick="ComparisonEditableTextBox_PreviewMouseDoubleClick"
                                                 KeyDown="ComparisonEditableTextBox_KeyDown" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Runs" Binding="{Binding RunCount}" IsReadOnly="True" Width="Auto" />
                            <DataGridTextColumn Header="Score" Binding="{Binding ScorePercent, StringFormat=0.##}" IsReadOnly="True" Width="Auto" />
                            <DataGridTextColumn Header="Critical" Binding="{Binding CriticalRecall, StringFormat=P1}" IsReadOnly="True" Width="Auto" />
                            <DataGridTextColumn Header="Stability" Binding="{Binding Stability, StringFormat=P1}" IsReadOnly="True" Width="Auto" />
                            <DataGridTextColumn Header="Evidence" Binding="{Binding EvidenceFidelity, StringFormat=P1}" IsReadOnly="True" Width="Auto" />
                            <DataGridTextColumn Header="Hallucination" Binding="{Binding HallucinationRate, StringFormat=P1}" IsReadOnly="True" Width="Auto" />
                            <DataGridTextColumn Header="Audit" Binding="{Binding AccountabilityScore, StringFormat=0.##}" IsReadOnly="True" Width="Auto" />
                            <DataGridTextColumn Header="Run2 Δ" Binding="{Binding Run2Delta, StringFormat=0.##}" IsReadOnly="True" Width="Auto" />
                            <DataGridTextColumn Header="Think Tok" Binding="{Binding ReasoningTokens, StringFormat=0.#}" IsReadOnly="True" Width="Auto" />
                            <DataGridTextColumn Header="Out Tok" Binding="{Binding OutputTokens, StringFormat=0.#}" IsReadOnly="True" Width="Auto" />
                            <DataGridTextColumn Header="Gesamt Tok" Binding="{Binding CompletionTokens, StringFormat=0.#}" IsReadOnly="True" Width="Auto" />
                            <DataGridTextColumn Header="Score/1k Tok" Binding="{Binding ScorePer1KTokens, StringFormat=0.##}" IsReadOnly="True" Width="Auto" />
                            <DataGridTextColumn Header="Median" Binding="{Binding ScoreMedian, StringFormat=0.##}" IsReadOnly="True" Width="Auto" />
                            <DataGridTextColumn Header="σ" Binding="{Binding ScoreStdDev, StringFormat=0.##}" IsReadOnly="True" Width="Auto" />
                            <DataGridTextColumn Header="Min" Binding="{Binding ScoreMin, StringFormat=0.##}" IsReadOnly="True" Width="Auto" />
                            <DataGridTextColumn Header="Max" Binding="{Binding ScoreMax, StringFormat=0.##}" IsReadOnly="True" Width="Auto" />
                            <DataGridTextColumn Header="Precision" Binding="{Binding Precision, StringFormat=P1}" IsReadOnly="True" Width="Auto" />
                            <DataGridTextColumn Header="Recall" Binding="{Binding Recall, StringFormat=P1}" IsReadOnly="True" Width="Auto" />
                            <DataGridTextColumn Header="F1" Binding="{Binding F1, StringFormat=P1}" IsReadOnly="True" Width="Auto" />
                            <DataGridTextColumn Header="Full TP" Binding="{Binding FullTruePositives}" IsReadOnly="True" Width="Auto" />
                            <DataGridTextColumn Header="Partial" Binding="{Binding PartialTruePositives}" IsReadOnly="True" Width="Auto" />
                            <DataGridTextColumn Header="FP" Binding="{Binding FalsePositives}" IsReadOnly="True" Width="Auto" />
                            <DataGridTextColumn Header="Missed" Binding="{Binding Missed}" IsReadOnly="True" Width="Auto" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>

        <DockPanel Grid.Row="3" Margin="4,8,4,0">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button x:Name="OpenReportButton" Content="Report öffnen" IsEnabled="False" Click="OpenReportButton_Click" />
                <Button x:Name="OpenFolderButton" Content="Ordner öffnen" IsEnabled="False" Click="OpenFolderButton_Click" />
            </StackPanel>
            <TextBlock x:Name="OutputPathTextBlock" VerticalAlignment="Center" Text="Noch kein Run gespeichert." Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" />
        </DockPanel>
    </Grid>
</Window>
